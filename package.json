{
  "name": "sota-adif-updater",
  "version": "1.0.0",
  "type": "module",
  "description": "A CLI utility to add SOTA and POTA references to an existing ADIF file",
  "main": "dist/index.js",
  "bin": {
    "sota-adif-updater": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
